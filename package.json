{
  "name": "kode",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "bin": {
    "kode": "bin/kode.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.113.0",
    "better-sqlite3": "12.10.1",
    "commander": "^12.0.0",
    "diff": "^9.0.0",
    "dotenv": "^16.4.0",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.6",
    "jsonc-parser": "^3.3.0",
    "openai": "^6.48.0",
    "pino": "^9.0.0",
    "tree-sitter-wasms": "0.1.13",
    "web-tree-sitter": "0.25.10",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "^20.12.0",
    "prettier": "^3.3.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
