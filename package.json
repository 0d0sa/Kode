{
  "name": "kode",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "bin": {
    "kode": "bin/kode.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "commander": "^12.0.0",
    "zod": "^3.23.0",
    "dotenv": "^16.4.0",
    "pino": "^9.0.0",
    "jsonc-parser": "^3.3.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "@types/node": "^20.12.0",
    "vitest": "^1.6.0",
    "@biomejs/biome": "^1.9.0",
    "prettier": "^3.3.0"
  }
}
