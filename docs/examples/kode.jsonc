{
  // Kode 配置示例（Phase 4）。
  // provider: "anthropic"（Anthropic 直连或兼容网关）| "openai" | "local"（OpenAI 兼容端点）
  "version": 1,
  "model": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-5",
    // API key 三选一（优先级从高到低）：
    // 1) apiKey 直写（见下，注意勿提交真实密钥）
    // 2) apiKeyEnv 指定环境变量名（推荐）
    // 3) provider 默认环境变量（ANTHROPIC_API_KEY / OPENAI_API_KEY）
    "apiKeyEnv": "ANTHROPIC_API_KEY",
    // "apiKey": "sk-...",                  // 直写示例（优先级最高）
    // "baseURL": "https://your-gateway/v1", // 兼容网关/自建端点
    // "maxTokens": 8192,
    // "temperature": 0.2,
  },
  // OpenAI 兼容端点示例（如官方 OpenAI、DeepSeek、本地 vLLM/Ollama 网关等）。
  // provider 为 "local" 时 baseURL 是必填项，防止误连公网 OpenAI：
  // "model": {
  //   "provider": "openai",          // 或 "local"（local 无需真实 key）
  //   "model": "gpt-4o-mini",
  //   "baseURL": "http://localhost:8000/v1",
  //   "apiKeyEnv": "OPENAI_API_KEY",
  // },
  "agent": {
    "maxSteps": 25,
    // Phase 1 兼容字段；Phase 3 不再按消息条数直接截断。
    "contextMessages": 20,
    "context": {
      "enabled": true,
      // provider 信息不准确时覆盖上下文窗口（常用于兼容/本地模型）：
      // "windowTokens": 128000,
      "safetyReserveTokens": 2048,
      "minimumOutputTokens": 1024,
      "preserveRecentTurns": 3,
      "toolResultTokens": 2048,
      "summaryTriggerRatio": 0.8,
    },
  },
  "codebase": {
    "enabled": true,
    "languages": ["typescript", "javascript", "python", "go", "rust"],
    // 缓存写入 ~/.kode/index/；首次构建后，后续启动会复用。
    "cache": "global",
    "refresh": "incremental",
    "maxFiles": 50000,
    "maxFileBytes": 2097152,
    "parseConcurrency": 4,
    "overviewTokens": 1800,
    // Phase 4 不上传源码或生成 embedding。
    "semanticSearch": {
      "enabled": false,
    },
  },
  "permissions": {
    "default": "confirm",
    "overrides": {
      "read_file": "allow",
      "list_symbols": "allow",
      "find_definition": "allow",
      "find_references": "allow",
      "module_dependencies": "allow",
    },
    // 规则按顺序匹配，第一条命中即生效。可组合工具、路径和简单命令前缀。
    // 工作区外路径在未命中显式规则时始终要求确认。
    "rules": [
      {
        "id": "deny-env-files",
        "decision": "deny",
        "tools": ["read_file", "grep", "write_file", "replace_in_file", "apply_patch"],
        "paths": [".env", ".env.*"],
      },
      {
        "id": "allow-project-search",
        "decision": "allow",
        "tools": [
          "glob",
          "grep",
          "list_symbols",
          "find_definition",
          "find_references",
          "module_dependencies",
        ],
        "paths": ["**/*"],
      },
      {
        "id": "allow-verification",
        "decision": "allow",
        "tools": ["run_command"],
        "commandPrefixes": ["pnpm test", "pnpm typecheck", "pnpm lint"],
      },
    ],
  },
  "rules": ["Always run `pnpm typecheck` after edits.", "Never edit files under dist/."],
  "logLevel": "info",
}
